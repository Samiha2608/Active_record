<% if legacy_record.errors.any? %>
  <div style="color: red;">
    <h2><%= pluralize(legacy_record.errors.count, "error") %> prevented this record from saving:</h2>
    <ul>
      <% legacy_record.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with(model: legacy_record, local: true) do |form| %>
  <div>
    <%= form.label :name %><br>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :info %><br>
    <%= form.text_area :info %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
